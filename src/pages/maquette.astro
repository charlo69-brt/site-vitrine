---
import "../styles/global.css";
import { profile, timeline, achievement } from "../data/profile";

const stations = timeline.filter((t) => t.org || t.current).slice(0, 6);
const firstScore = timeline[0].score;
const lastScore = timeline[timeline.length - 1].score;

const experienceEntries = timeline.filter((e) => e.kind === "experience");
const firstExp = new Date(`${experienceEntries[0].date}-01`);
const expYears = Math.floor((Date.now() - firstExp.getTime()) / (1000 * 60 * 60 * 24 * 365.25));

const kpis = [
  { value: expYears, suffix: "+", label: "Ans sur le terrain" },
  { value: timeline.length, suffix: "", label: "Étapes franchies" },
  { value: lastScore, suffix: "/100", label: "Indice de progression" },
  { value: 1, suffix: "ʳᵉ", label: "Place / 60 — Négociation" },
];

// Donut d'allocation (valeurs illustratives)
const allocation = [
  { label: "Immobilier", value: 40, color: "#4d8bff" },
  { label: "Épargne réglementée", value: 25, color: "#1fae6e" },
  { label: "Marchés financiers", value: 20, color: "#7c5cff" },
  { label: "Prévoyance", value: 15, color: "#caa46b" },
];
const R = 70;
const C = 2 * Math.PI * R;
let cum = 0;
const segs = allocation.map((a, i) => {
  const len = (a.value / 100) * C;
  const start = cum * 3.6 - 90;
  cum += a.value;
  return { ...a, len, start, delay: i * 160 };
});
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" />
    <title>Maquette — {profile.name}</title>
  </head>
  <body class="mk">
    <div class="mk-progress" id="mk-progress" aria-hidden="true"></div>
    <a href="/" class="mk-back">← Retour au site</a>

    <!-- HERO 3D -->
    <header class="mk-hero">
      <div class="mk-scene" id="mk-scene">
        <div class="mk-layer mk-aurora" data-depth="8" aria-hidden="true"></div>
        <div class="mk-layer mk-floor" aria-hidden="true"></div>
        <div class="mk-layer mk-horizon" aria-hidden="true"></div>
        <div class="mk-hero-inner mk-layer" data-depth="-14">
          <p class="mk-kicker"><span class="dot"></span>{profile.role} · ouvert aux opportunités</p>
          <h1>LA <span class="grad">TRAJECTOIRE</span><br />PATRIMONIALE</h1>
          <p class="mk-sub">{profile.name} — naviguez à travers un parcours qui ne cesse de monter. Faites défiler pour avancer dans la courbe.</p>
          <div class="mk-cta-row">
            <a href="#journey" class="btn btn-primary">Commencer la visite</a>
            <a href="/#contact" class="btn mk-ghost">Me contacter</a>
          </div>
        </div>
      </div>
      <span class="mk-scroll" aria-hidden="true"><span></span></span>
    </header>

    <!-- BANDEAU KPI -->
    <section class="mk-kpis">
      {kpis.map((k) => (
        <div class="mk-kpi" data-card>
          <span class="mk-kpi-val"><b data-count={k.value}>0</b>{k.suffix}</span>
          <span class="mk-kpi-label">{k.label}</span>
        </div>
      ))}
    </section>

    <!-- JOURNEY : ligne de cotation -->
    <main class="mk-journey" id="journey">
      <p class="mk-section-kicker">Le parcours</p>
      <h2 class="mk-section-title">Chaque étape, <span class="grad">un palier franchi</span></h2>

      <div class="mk-spine" aria-hidden="true"><div class="mk-spine-fill" id="mk-spine-fill"></div></div>

      <ol class="mk-stations">
        {stations.map((s, i) => (
          <li class={`mk-station ${i % 2 ? "right" : "left"}`} data-station data-card data-score={s.score}>
            <span class="mk-node" aria-hidden="true"></span>
            <article class="mk-card">
              <span class="mk-tag">{s.kind === "education" ? "Formation" : "Expérience"}</span>
              <span class="mk-score">{s.score}<i>/100</i></span>
              <h3>{s.label}</h3>
              {s.org && <p class="mk-org">{s.org}</p>}
              <p class="mk-period">{s.period}</p>
            </article>
          </li>
        ))}
      </ol>
    </main>

    <!-- ALLOCATION -->
    <section class="mk-alloc">
      <p class="mk-section-kicker">La méthode</p>
      <h2 class="mk-section-title">Une allocation <span class="grad">équilibrée</span></h2>
      <div class="mk-alloc-grid" data-card>
        <div class="mk-donut-wrap">
          <svg viewBox="0 0 200 200" class="mk-donut" role="img" aria-label="Allocation illustrative">
            <circle cx="100" cy="100" r={R} class="mk-donut-track" />
            {segs.map((s) => (
              <circle cx="100" cy="100" r={R} class="mk-seg" stroke={s.color}
                stroke-dasharray={`0 ${C}`}
                style={`--dash:${s.len.toFixed(2)} ${C.toFixed(2)}; transform:rotate(${s.start}deg); transition-delay:${s.delay}ms`} />
            ))}
          </svg>
          <div class="mk-donut-center"><b>4</b><span>piliers</span></div>
        </div>
        <ul class="mk-legend">
          {segs.map((s) => (
            <li><span class="sw" style={`background:${s.color}`}></span><span class="nm">{s.label}</span><span class="vl">{s.value}%</span></li>
          ))}
        </ul>
      </div>
    </section>

    <!-- SOMMET -->
    <section class="mk-summit">
      <span class="mk-summit-badge">SOMMET ACTUEL · {lastScore}/100</span>
      <h2>Et la suite s'écrit <span class="grad">avec vous</span>.</h2>
      <p class="mk-summit-sub">{achievement.title} — {achievement.description}</p>
      <a href="/#contact" class="btn btn-primary">Travaillons ensemble</a>
    </section>

    <style>
      .mk { margin: 0; background: #060b18; color: #eaf0ff; font-family: var(--font-sans); overflow-x: hidden; }
      .mk h1, .mk h2, .mk h3 { font-family: var(--font-display); }
      .grad { background: linear-gradient(110deg, #4d8bff, #1fae6e); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: #1fae6e; display: inline-block; animation: pulse-dot 2s ease-out infinite; }
      .mk-ghost { background: rgba(255,255,255,0.06); color: #fff; border: 1px solid rgba(255,255,255,0.22); }
      .mk-ghost:hover { border-color: #fff; }

      .mk-progress { position: fixed; top: 0; left: 0; height: 3px; width: 100%; transform: scaleX(0); transform-origin: left; background: linear-gradient(90deg, #4d8bff, #1fae6e); z-index: 100; }
      .mk-back { position: fixed; top: 1.1rem; right: 1.2rem; z-index: 100; font-size: 0.82rem; font-weight: 600; color: #cfe0ff; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); padding: 0.4rem 0.85rem; border-radius: 999px; backdrop-filter: blur(6px); }

      .mk-section-kicker { text-align: center; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; font-size: 0.78rem; color: #8fb3ff; margin: 0 0 0.6rem; }
      .mk-section-title { text-align: center; font-size: clamp(1.7rem, 1rem + 2.6vw, 2.8rem); margin: 0 0 3rem; }

      /* HERO 3D */
      .mk-hero { position: relative; min-height: 100vh; overflow: hidden; }
      .mk-scene { position: absolute; inset: 0; perspective: 900px; transform-style: preserve-3d; display: flex; align-items: center; }
      .mk-layer { will-change: transform; }
      .mk-aurora { position: absolute; inset: 0; }
      .mk-aurora::before, .mk-aurora::after { content: ""; position: absolute; width: 60vw; height: 60vw; border-radius: 50%; filter: blur(90px); opacity: 0.5; }
      .mk-aurora::before { top: -25%; right: -8%; background: radial-gradient(circle, rgba(47,111,237,0.85), transparent 70%); animation: float-y 12s ease-in-out infinite; }
      .mk-aurora::after { bottom: 10%; left: -8%; background: radial-gradient(circle, rgba(31,174,110,0.6), transparent 70%); animation: float-y 15s ease-in-out infinite reverse; }

      /* Sol en perspective qui défile vers le spectateur */
      .mk-floor { position: absolute; left: -50%; right: -50%; bottom: -2%; height: 60%; transform: perspective(420px) rotateX(74deg); transform-origin: bottom center;
        background-image: linear-gradient(rgba(77,139,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(77,139,255,0.35) 1px, transparent 1px);
        background-size: 60px 60px; animation: floor-move 4s linear infinite;
        -webkit-mask-image: linear-gradient(0deg, #000 5%, transparent 75%); mask-image: linear-gradient(0deg, #000 5%, transparent 75%); }
      @keyframes floor-move { to { background-position: 0 60px; } }
      .mk-horizon { position: absolute; left: 0; right: 0; bottom: 38%; height: 2px; background: linear-gradient(90deg, transparent, #4d8bff, #1fae6e, transparent); filter: blur(1px); box-shadow: 0 0 40px 8px rgba(77,139,255,0.5); }

      .mk-hero-inner { position: relative; z-index: 2; max-width: var(--container-width); margin: 0 auto; padding: 0 1.5rem; }
      .mk-kicker { display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #8fb3ff; margin-bottom: 1.4rem; }
      .mk-hero h1 { font-size: clamp(2.6rem, 1rem + 9vw, 7rem); line-height: 0.95; letter-spacing: -0.03em; margin: 0 0 1.4rem; text-shadow: 0 10px 60px rgba(0,0,0,0.5); }
      .mk-sub { max-width: 42ch; color: #aebbd6; font-size: 1.1rem; margin-bottom: 2rem; }
      .mk-cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
      .mk-scroll { position: absolute; bottom: 1.8rem; left: 50%; transform: translateX(-50%); width: 24px; height: 40px; border: 2px solid rgba(255,255,255,0.35); border-radius: 999px; z-index: 3; }
      .mk-scroll span { position: absolute; top: 7px; left: 50%; width: 4px; height: 8px; margin-left: -2px; background: #fff; border-radius: 2px; animation: scroll-cue 1.8s ease-in-out infinite; }
      @keyframes scroll-cue { 0% { opacity: 0; transform: translateY(0); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(13px); } }

      /* KPI */
      .mk-kpis { position: relative; z-index: 3; max-width: var(--container-width); margin: -4rem auto 0; padding: 0 1.5rem; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
      .mk-kpi { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 1.4rem; text-align: center; backdrop-filter: blur(10px); }
      .mk-kpi-val { display: block; font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: #fff; }
      .mk-kpi-val b { color: #7ef0bd; }
      .mk-kpi-label { display: block; font-size: 0.78rem; color: #9db3dd; margin-top: 0.3rem; }

      /* JOURNEY */
      .mk-journey { position: relative; max-width: 980px; margin: 0 auto; padding: 7rem 1.5rem 4rem; }
      .mk-spine { position: absolute; top: 12rem; bottom: 2rem; left: 50%; width: 2px; transform: translateX(-50%); background: rgba(255,255,255,0.1); }
      .mk-spine-fill { position: absolute; top: 0; left: 0; width: 100%; height: 0; background: linear-gradient(180deg, #4d8bff, #1fae6e); box-shadow: 0 0 16px rgba(77,139,255,0.7); }
      .mk-stations { list-style: none; margin: 0; padding: 0; }
      .mk-station { position: relative; width: 50%; padding: 2rem 2.5rem; box-sizing: border-box; }
      .mk-station.left { left: 0; text-align: right; }
      .mk-station.right { left: 50%; text-align: left; }
      .mk-node { position: absolute; top: 2.5rem; width: 16px; height: 16px; border-radius: 50%; background: #0a1224; border: 2px solid #4d8bff; box-shadow: 0 0 0 4px rgba(77,139,255,0.15); transition: all 0.4s ease; }
      .mk-station.left .mk-node { right: -8px; } .mk-station.right .mk-node { left: -8px; }
      .mk-station.in .mk-node { background: #1fae6e; border-color: #1fae6e; box-shadow: 0 0 0 5px rgba(31,174,110,0.25), 0 0 18px rgba(31,174,110,0.85); }
      .mk-card { display: inline-block; text-align: left; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 1.4rem 1.6rem; backdrop-filter: blur(8px); max-width: 360px; }
      .mk-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #8fb3ff; background: rgba(77,139,255,0.12); border: 1px solid rgba(77,139,255,0.3); padding: 0.2rem 0.55rem; border-radius: 999px; margin-bottom: 0.8rem; }
      .mk-score { float: right; font-family: var(--font-display); font-weight: 700; font-size: 1.4rem; color: #7ef0bd; }
      .mk-score i { font-style: normal; font-size: 0.75rem; color: #6b7aa0; }
      .mk-card h3 { font-size: 1.1rem; margin: 0 0 0.4rem; }
      .mk-org { color: #c7d0e6; font-size: 0.9rem; margin: 0 0 0.3rem; } .mk-period { color: #8fa0c7; font-size: 0.8rem; margin: 0; }

      /* ALLOCATION */
      .mk-alloc { max-width: 880px; margin: 0 auto; padding: 5rem 1.5rem; }
      .mk-alloc-grid { display: grid; grid-template-columns: 240px 1fr; gap: 2.5rem; align-items: center; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 2rem; }
      .mk-donut-wrap { position: relative; }
      .mk-donut { width: 100%; height: auto; }
      .mk-donut-track { fill: none; stroke: rgba(255,255,255,0.08); stroke-width: 22; }
      .mk-seg { fill: none; stroke-width: 22; transform-origin: 100px 100px; transition: stroke-dasharray 1.1s cubic-bezier(0.22,1,0.36,1); }
      .mk-alloc-grid.in .mk-seg { stroke-dasharray: var(--dash); }
      .mk-donut-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
      .mk-donut-center b { font-family: var(--font-display); font-size: 2.2rem; } .mk-donut-center span { font-size: 0.78rem; color: #9db3dd; }
      .mk-legend { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
      .mk-legend li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.92rem; color: #dbe2f3; }
      .mk-legend .sw { width: 11px; height: 11px; border-radius: 3px; } .mk-legend .nm { flex: 1; } .mk-legend .vl { font-family: var(--font-display); font-weight: 600; color: #fff; }

      /* SOMMET */
      .mk-summit { text-align: center; padding: 5rem 1.5rem 8rem; }
      .mk-summit-badge { display: inline-block; font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.08em; color: #0a1224; background: linear-gradient(110deg, #4d8bff, #1fae6e); padding: 0.45rem 1rem; border-radius: 999px; margin-bottom: 1.5rem; }
      .mk-summit h2 { font-size: clamp(1.8rem, 1rem + 3vw, 3rem); margin: 0 0 1rem; }
      .mk-summit-sub { color: #aebbd6; margin: 0 0 2rem; }

      /* Entrée 3D des cartes */
      [data-card] { opacity: 0; transform: perspective(1000px) rotateX(10deg) translateY(45px) translateZ(-50px); transition: opacity 0.7s ease, transform 0.8s cubic-bezier(0.22,1,0.36,1); }
      [data-card].in { opacity: 1; transform: none; }

      @media (max-width: 760px) {
        .mk-kpis { grid-template-columns: repeat(2, 1fr); }
        .mk-spine { left: 16px; }
        .mk-station, .mk-station.left, .mk-station.right { width: 100%; left: 0; text-align: left; padding: 1.4rem 0 1.4rem 2.5rem; }
        .mk-station .mk-node, .mk-station.left .mk-node, .mk-station.right .mk-node { left: 9px; right: auto; }
        .mk-alloc-grid { grid-template-columns: 1fr; justify-items: center; text-align: center; }
      }
      @media (prefers-reduced-motion: reduce) {
        [data-card] { opacity: 1; transform: none; }
        .mk-floor, .mk-aurora::before, .mk-aurora::after { animation: none; }
      }
    </style>

    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const finePointer = window.matchMedia("(pointer: fine)").matches;
      const progress = document.getElementById("mk-progress");
      const fill = document.getElementById("mk-spine-fill");
      const spine = fill?.parentElement as HTMLElement | null;
      const stations = Array.from(document.querySelectorAll<HTMLElement>("[data-station]"));

      // Apparitions (cartes + stations + donut)
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("in")),
        { threshold: 0.25 },
      );
      document.querySelectorAll("[data-card]").forEach((el) => (reduce ? el.classList.add("in") : io.observe(el)));

      // Compteurs KPI
      const counters = Array.from(document.querySelectorAll<HTMLElement>("[data-count]"));
      const cio = new IntersectionObserver((entries, obs) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const el = e.target as HTMLElement;
          const target = Number(el.dataset.count) || 0;
          const t0 = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - t0) / 800, 1);
            el.textContent = String(Math.round((1 - Math.pow(1 - p, 3)) * target));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          obs.unobserve(el);
        });
      }, { threshold: 0.6 });
      counters.forEach((el) => cio.observe(el));

      // Parallax 3D à la souris sur le hero
      const scene = document.getElementById("mk-scene");
      if (scene && finePointer && !reduce) {
        const layers = Array.from(scene.querySelectorAll<HTMLElement>("[data-depth]"));
        scene.addEventListener("pointermove", (ev) => {
          const cx = (ev.clientX / window.innerWidth - 0.5) * 2;
          const cy = (ev.clientY / window.innerHeight - 0.5) * 2;
          for (const l of layers) {
            const d = Number(l.dataset.depth) || 0;
            l.style.transform = `translate3d(${cx * d}px, ${cy * d}px, 0)`;
          }
        });
        scene.addEventListener("pointerleave", () => layers.forEach((l) => (l.style.transform = "")));
      }

      // Progression + remplissage de la ligne
      let ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const doc = document.documentElement;
          const max = doc.scrollHeight - doc.clientHeight;
          if (progress) progress.style.transform = `scaleX(${max > 0 ? doc.scrollTop / max : 0})`;
          if (fill && spine) {
            const rect = spine.getBoundingClientRect();
            fill.style.height = `${Math.min(Math.max(window.innerHeight / 2 - rect.top, 0), rect.height)}px`;
          }
          ticking = false;
        });
      }
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    </script>
  </body>
</html>
