---
const services = [
  { title: "Bilan patrimonial", text: "Cartographie complète des actifs, passifs et objectifs de vie pour poser une stratégie claire.", icon: "compass" },
  { title: "Allocation d'actifs", text: "Répartition équilibrée entre immobilier, épargne et marchés selon le profil de risque.", icon: "pie" },
  { title: "Financement immobilier", text: "Montage et négociation de prêts, effet de levier et optimisation de la capacité d'emprunt.", icon: "home" },
  { title: "Optimisation fiscale", text: "Enveloppes adaptées et arbitrages pour réduire la pression fiscale dans la durée.", icon: "shield" },
];

const icons: Record<string, string> = {
  compass: '<circle cx="12" cy="12" r="9"/><polygon points="16 8 11 11 8 16 13 13 16 8"/>',
  pie: '<path d="M12 2a10 10 0 1 0 10 10H12z"/><path d="M12 2v10h10A10 10 0 0 0 12 2z"/>',
  home: '<path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  shield: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="M9 12l2 2 4-4"/>',
};

const allocation = [
  { label: "Immobilier", value: 40, color: "#c8a96a" },
  { label: "Épargne réglementée", value: 25, color: "#5fb98a" },
  { label: "Marchés financiers", value: 20, color: "#5a82d8" },
  { label: "Prévoyance", value: 15, color: "#b58bd0" },
];
const R = 70, C = 2 * Math.PI * R;
// Positionnement robuste par stroke-dashoffset cumulé (cross-browser), pas par rotation de chaque <circle>.
let acc = 0;
const segments = allocation.map((a, i) => {
  const len = (a.value / 100) * C;
  const offset = -acc;
  acc += len;
  return { ...a, len, offset, delay: i * 160 };
});
---

<section class="section approche" id="approche">
  <span class="glow glow-blue ap-glow" data-depth="-0.1" aria-hidden="true"></span>
  <div class="container" data-scene>
    <p class="kicker" data-reveal>Méthode</p>
    <h2 class="section-title" data-reveal style="transition-delay: 60ms">Comment j'accompagne <span class="gold-text">mes clients</span></h2>

    <div class="approche-grid">
      <ul class="services">
        {services.map((s, i) => (
          <li class="service-card glass" data-reveal data-tilt="6" style={`transition-delay:${i * 90}ms`}>
            <span class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
            </span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </li>
        ))}
      </ul>

      <figure class="donut-card glass" data-reveal style="transition-delay: 120ms">
        <figcaption class="donut-title">Exemple d'allocation patrimoniale équilibrée</figcaption>
        <div class="donut-wrap">
          <svg viewBox="0 0 200 200" class="donut" role="img" aria-label="Allocation illustrative">
            <circle cx="100" cy="100" r={R} class="donut-track" />
            {segments.map((s) => (
              <circle cx="100" cy="100" r={R} class="donut-seg" stroke={s.color} stroke-dasharray={`0 ${C.toFixed(2)}`} stroke-dashoffset={s.offset.toFixed(2)}
                style={`--dash:${s.len.toFixed(2)} ${C.toFixed(2)}; transition-delay:${s.delay}ms`} />
            ))}
          </svg>
          <div class="donut-center"><b>4</b><span>piliers</span></div>
        </div>
        <ul class="donut-legend">
          {segments.map((s) => (
            <li><span class="sw" style={`background:${s.color}`}></span><span class="nm">{s.label}</span><span class="vl">{s.value}%</span></li>
          ))}
        </ul>
      </figure>
    </div>
  </div>
</section>

<style>
  .approche { overflow: hidden; }
  .ap-glow { width: 30rem; height: 30rem; top: 20%; right: -12rem; opacity: 0.3; }
  .approche-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.25fr 1fr; gap: 1.75rem; align-items: start; }
  .services { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .service-card { padding: 1.6rem; position: relative; transition: transform 0.3s ease, border-color 0.3s ease; }
  .service-card:hover { border-color: var(--line-strong); }
  .service-icon { display: inline-flex; align-items: center; justify-content: center; width: 2.8rem; height: 2.8rem; border-radius: 12px; margin-bottom: 1rem; color: var(--gold); background: var(--gold-soft); border: 1px solid var(--line-strong); }
  .service-card h3 { font-size: 1.25rem; color: var(--ink); margin-bottom: 0.45rem; }
  .service-card p { font-size: 0.92rem; color: var(--muted); }

  .donut-card { padding: 1.85rem; }
  .donut-title { font-family: var(--font-display); font-size: 1.15rem; color: var(--ink); margin-bottom: 1.25rem; }
  .donut-wrap { position: relative; width: 100%; max-width: 240px; margin: 0 auto 1.5rem; }
  .donut { width: 100%; height: auto; display: block; transform: rotate(-90deg); }
  .donut-track { fill: none; stroke: rgba(236, 232, 223, 0.07); stroke-width: 22; }
  .donut-seg { fill: none; stroke-width: 22; transition: stroke-dasharray 1.1s cubic-bezier(0.22, 1, 0.36, 1); }
  .donut-card.is-visible .donut-seg { stroke-dasharray: var(--dash); }
  .donut-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .donut-center b { font-family: var(--font-display); font-size: 2.4rem; color: var(--ink); }
  .donut-center span { font-size: 0.78rem; color: var(--muted); }
  .donut-legend { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
  .donut-legend li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: var(--muted); }
  .sw { width: 11px; height: 11px; border-radius: 3px; flex-shrink: 0; }
  .nm { flex: 1; } .vl { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; color: var(--ink); }

  @media (max-width: 860px) { .approche-grid { grid-template-columns: 1fr; } }
  @media (max-width: 520px) { .services { grid-template-columns: 1fr; } }
</style>
