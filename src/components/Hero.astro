---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.png";
import { profile, timeline, achievement } from "../data/profile";

const age = new Date().getFullYear() - profile.birthYear;
const experienceEntries = timeline.filter((e) => e.kind === "experience");
const educationEntries = timeline.filter((e) => e.kind === "education");
const firstExp = new Date(`${experienceEntries[0].date}-01`);
const expYears = Math.floor((Date.now() - firstExp.getTime()) / (1000 * 60 * 60 * 24 * 365.25));

const stats = [
  { value: expYears, suffix: "+", label: "Ans sur le terrain" },
  { value: educationEntries.length, suffix: "", label: "Étapes de formation" },
  { value: age, suffix: "", label: "Ans" },
];

const trust = ["LCL", "ESBanque", "BTS NDRC", "Century 21", "Laforêt"];
---

<section class="hero" id="accueil">
  <div class="hero-decor" aria-hidden="true">
    <span class="glow glow-gold g1" data-depth="0.16"></span>
    <span class="glow glow-blue g2" data-depth="-0.1"></span>
    <div class="floor bg-grid-soft"></div>
  </div>

  <div class="container">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="kicker">{profile.role} · Ouvert aux opportunités</p>
        <h1 class="display">Bâtir des stratégies<br /><span class="gold-text">patrimoniales</span><br />qui durent.</h1>
        <p class="hero-name">{profile.name}</p>
        <p class="lead">{profile.tagline}</p>

        <div class="actions">
          <a href="#contact" class="btn btn-gold" data-magnetic>Me contacter</a>
          <a href="#parcours" class="btn btn-ghost" data-magnetic>Découvrir le parcours</a>
        </div>

        <div class="trust" data-reveal>
          <span class="trust-label">Parcours forgé chez</span>
          <ul class="trust-row">{trust.map((t) => <li>{t}</li>)}</ul>
        </div>
      </div>

      <div class="hero-photo" data-reveal>
        <figure class="photo-frame">
          <Image src={portrait} alt={profile.name} width={433} height={576} class="photo-img" />
          <canvas class="ink-canvas" id="ink-canvas" aria-hidden="true"></canvas>
        </figure>
      </div>
    </div>

    <div class="hero-stats" data-reveal>
      {stats.map((s) => (
        <div class="hstat">
          <span class="hstat-value" data-animate-count={s.value} data-count-suffix={s.suffix}>{s.value}{s.suffix}</span>
          <span class="hstat-label">{s.label}</span>
        </div>
      ))}
      <div class="hstat hstat-quote">
        <span class="hstat-value gold-text">«&nbsp;{achievement.description}&nbsp;»</span>
        <span class="hstat-label">{achievement.title}</span>
      </div>
    </div>
  </div>

  <a href="#approche" class="scroll-cue" aria-label="Descendre"><span></span></a>
</section>

<script>
  // Révélation à l'encre : un voile recouvre la photo et se "creuse" au passage du curseur.
  const canvas = document.getElementById("ink-canvas") as HTMLCanvasElement | null;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canvas && !reduce) {
    const ctx = canvas.getContext("2d");
    const parent = canvas.parentElement;

    if (ctx && parent) {
      const maskColor: [number, number, number] = [8, 13, 26];
      const brushSize = 128;
      const lifetime = 600;
      const rStart = 10;
      const rVary = 0.45;
      const stampStep = 10;
      const maxStamps = 200;
      const segments = 36;
      const wobble: [number, number, number] = [0.14, 0.08, 0.05];
      const gradientInnerRadius = 0.2;
      const gradientStops: [number, number, number] = [0.95, 0.88, 0];

      interface Stamp { x: number; y: number; born: number; seed: number; rmax: number; }
      const stamps: Stamp[] = [];
      let running = false;
      let lastPos: { x: number; y: number } | null = null;
      let dims = { w: 0, h: 0 };

      const fillMask = (w: number, h: number) => {
        ctx.globalCompositeOperation = "source-over";
        ctx.fillStyle = `rgb(${maskColor[0]},${maskColor[1]},${maskColor[2]})`;
        ctx.fillRect(0, 0, w, h);
      };

      const resize = () => {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const rect = parent.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        dims = { w, h };
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        canvas.style.width = `${w}px`;
        canvas.style.height = `${h}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        fillMask(w, h);
      };

      const carveInk = (x: number, y: number, r: number, seed: number, alpha: number) => {
        const g = ctx.createRadialGradient(x, y, r * gradientInnerRadius, x, y, r);
        g.addColorStop(0, `rgba(0,0,0,${gradientStops[0] * alpha})`);
        g.addColorStop(0.5, `rgba(0,0,0,${gradientStops[1] * alpha})`);
        g.addColorStop(1, `rgba(0,0,0,${gradientStops[2] * alpha})`);
        ctx.fillStyle = g;
        ctx.beginPath();
        for (let i = 0; i <= segments; i++) {
          const a = (i / segments) * Math.PI * 2;
          const wob =
            0.78 +
            wobble[0] * Math.sin(a * 3 + seed) +
            wobble[1] * Math.sin(a * 5 + seed * 2.1) +
            wobble[2] * Math.sin(a * 7 + seed * 0.7);
          const px = x + Math.cos(a) * r * wob;
          const py = y + Math.sin(a) * r * wob;
          i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
        }
        ctx.closePath();
        ctx.fill();
      };

      const addStamp = (x: number, y: number) => {
        if (stamps.length >= maxStamps) stamps.shift();
        stamps.push({
          x, y,
          born: performance.now(),
          seed: Math.random() * Math.PI * 2,
          rmax: brushSize * (1 - rVary + Math.random() * rVary),
        });
      };

      const stampAlong = (x: number, y: number) => {
        if (!lastPos) {
          addStamp(x, y);
        } else {
          const dx = x - lastPos.x;
          const dy = y - lastPos.y;
          const dist = Math.hypot(dx, dy);
          const steps = Math.max(1, Math.ceil(dist / stampStep));
          for (let i = 1; i <= steps; i++) {
            addStamp(lastPos.x + (dx * i) / steps, lastPos.y + (dy * i) / steps);
          }
        }
        lastPos = { x, y };
      };

      const loop = () => {
        const { w, h } = dims;
        const now = performance.now();
        fillMask(w, h);
        ctx.globalCompositeOperation = "destination-out";
        for (let i = stamps.length - 1; i >= 0; i--) {
          const t = (now - stamps[i].born) / lifetime;
          if (t >= 1) { stamps.splice(i, 1); continue; }
          const ease = 1 - Math.pow(1 - t, 3);
          const r = rStart + (stamps[i].rmax - rStart) * ease;
          const alpha = 1 - t * t;
          carveInk(stamps[i].x, stamps[i].y, r, stamps[i].seed, alpha);
        }
        if (stamps.length) requestAnimationFrame(loop);
        else running = false;
      };

      const startLoop = () => {
        if (!running) { running = true; requestAnimationFrame(loop); }
      };

      const relPos = (e: PointerEvent) => {
        const rect = canvas.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      };

      canvas.addEventListener("pointerenter", (e) => {
        const p = relPos(e);
        lastPos = p;
        stampAlong(p.x, p.y);
        startLoop();
      });
      canvas.addEventListener("pointermove", (e) => {
        const p = relPos(e);
        stampAlong(p.x, p.y);
        startLoop();
      });
      canvas.addEventListener("pointerleave", () => { lastPos = null; });

      resize();
      window.addEventListener("resize", resize, { passive: true });
    }
  }
</script>

<style>
  .hero { position: relative; overflow: hidden; padding: 8rem 0 3rem; background: radial-gradient(130% 90% at 85% -10%, #14203f 0%, var(--bg) 55%); }
  .hero-decor { position: absolute; inset: 0; z-index: 0; }
  .g1 { width: 32rem; height: 32rem; top: -12rem; right: -8rem; }
  .g2 { width: 26rem; height: 26rem; bottom: -8rem; left: -8rem; }
  .floor { position: absolute; left: -40%; right: -40%; bottom: -5%; height: 45%; transform: perspective(460px) rotateX(76deg); transform-origin: bottom center; opacity: 0.4; -webkit-mask-image: linear-gradient(0deg, #000 5%, transparent 70%); mask-image: linear-gradient(0deg, #000 5%, transparent 70%); animation: floor-move 5s linear infinite; }

  .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 3.5rem; }

  .kicker { color: var(--gold); }
  .hero-text h1 { margin-bottom: 0.9rem; }
  .hero-name { font-family: var(--font-display); font-style: italic; font-size: 1.4rem; color: var(--gold-bright); margin-bottom: 1rem; }
  .lead { margin-bottom: 2rem; }
  .actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.2rem; }

  .trust { display: flex; flex-direction: column; gap: 0.85rem; }
  .trust-label { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted-2); }
  .trust-label::after { content: ""; flex: 1; height: 1px; background: linear-gradient(90deg, var(--line-strong), transparent); }
  .trust-row { list-style: none; display: flex; flex-wrap: wrap; align-items: center; gap: 1.4rem; }
  .trust-row li { position: relative; font-family: var(--font-display); font-style: italic; font-size: 1.15rem; color: var(--ink); transition: color 0.2s ease; }
  .trust-row li:not(:first-child)::before { content: ""; position: absolute; left: -0.85rem; top: 50%; width: 5px; height: 5px; transform: translateY(-50%) rotate(45deg); background: var(--gold); opacity: 0.8; }
  .trust-row li:hover { color: var(--gold-bright); }

  /* ----- Portrait + révélation à l'encre ----- */
  .hero-photo { display: flex; align-items: center; justify-content: center; min-height: 440px; }
  .photo-frame {
    position: relative; margin: 0;
    width: min(360px, 80%); aspect-ratio: 433 / 576;
    border-radius: 18px; overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--bg);
    box-shadow: var(--shadow-lg), 0 0 60px rgba(200, 169, 106, 0.18);
  }
  .photo-img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: 50% 22%; }
  .ink-canvas { position: absolute; inset: 0; z-index: 1; cursor: none; }

  /* Bandeau stats pleine largeur */
  .hero-stats { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 3rem; padding-top: 2.2rem; border-top: 1px solid var(--line); }
  .hstat-value { display: block; font-family: var(--font-display); font-size: 2.2rem; font-weight: 600; color: var(--ink); line-height: 1.1; }
  .hstat-label { display: block; font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }
  .hstat-quote .hstat-value { font-size: 1.25rem; }

  .scroll-cue { position: absolute; bottom: 1.2rem; left: 50%; transform: translateX(-50%); width: 22px; height: 36px; border: 1px solid var(--line-strong); border-radius: 999px; z-index: 1; }
  .scroll-cue span { position: absolute; top: 6px; left: 50%; width: 3px; height: 7px; margin-left: -1.5px; background: var(--gold); border-radius: 2px; animation: scroll-cue 1.8s ease-in-out infinite; }
  @keyframes scroll-cue { 0% { opacity: 0; transform: translateY(0); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(12px); } }

  @media (max-width: 920px) {
    .hero { padding-top: 6.5rem; }
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-photo { min-height: 0; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); gap: 1.25rem 1rem; }
    .scroll-cue { display: none; }
  }
  @media (max-width: 480px) { .hero-stats { grid-template-columns: 1fr 1fr; } .hstat-quote { grid-column: 1 / -1; } }
  @media (prefers-reduced-motion: reduce) { .floor { animation: none; } .ink-canvas { display: none; } }
</style>
