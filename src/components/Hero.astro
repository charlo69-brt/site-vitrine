---
import { Image } from "astro:assets";
import photo from "../assets/photo.png";
import { profile } from "../data/profile";

const birth = new Date(profile.birthDate);
const ageMs = Date.now() - birth.getTime();
const age = Math.floor(ageMs / (1000 * 60 * 60 * 24 * 365.25));

const facts = [`${age} ans`, profile.location, profile.drivingLicense];
---

<section class="hero" id="accueil">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="section-label">{profile.role}</p>
      <h1>{profile.name}</h1>
      <p class="tagline">{profile.tagline}</p>

      <ul class="facts">
        {facts.map((fact) => <li>{fact}</li>)}
      </ul>

      <div class="actions">
        <a href="#contact" class="btn btn-primary">Me contacter</a>
        <a href="#parcours" class="btn btn-secondary">Voir mon parcours</a>
      </div>
    </div>

    <div class="hero-photo">
      <Image src={photo} alt={profile.name} width={360} height={420} />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, #eef1f6 0%, var(--color-bg) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-text h1 {
    font-size: 3rem;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .tagline {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin-bottom: 2rem;
  }

  .facts li {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-photo {
    justify-self: center;
  }

  .hero-photo img {
    width: 100%;
    max-width: 320px;
    border-radius: 16px;
    background: var(--color-navy);
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text h1 {
      font-size: 2.2rem;
    }

    .tagline {
      margin-left: auto;
      margin-right: auto;
    }

    .facts,
    .actions {
      justify-content: center;
    }

    .hero-photo {
      order: -1;
    }
  }
</style>
