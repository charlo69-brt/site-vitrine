---
import { profile } from "../data/profile";
---

<section class="hero-video-section" id="accueil">
  <!-- Titre réel pour le SEO et les lecteurs d'écran (le texte de la vidéo n'est pas lisible par les machines) -->
  <h1 class="sr-only">{profile.name} — {profile.role}. Bâtir une stratégie patrimoniale qui dure.</h1>

  <video class="hv-media" autoplay muted loop playsinline preload="auto" poster="/hero-patrimoine-poster.jpg" aria-hidden="true">
    <source src="/hero-patrimoine.mp4" type="video/mp4" />
  </video>
  <div class="hv-scrim" aria-hidden="true"></div>

  <div class="hv-overlay">
    <span class="hv-avail"><span class="hv-dot" aria-hidden="true"></span>Ouvert aux opportunités</span>
    <div class="hv-btns">
      <a href="#contact" class="btn btn-gold" data-magnetic>Prendre rendez-vous</a>
      <a href="#parcours" class="btn btn-ghost" data-magnetic>Découvrir le parcours</a>
    </div>
  </div>
</section>

<style>
  .hero-video-section {
    position: relative; width: 100%;
    height: calc(100vh - 4.75rem); height: calc(100svh - 4.75rem); min-height: 560px;
    overflow: hidden; background: var(--bg);
  }
  .hv-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  @media (max-width: 900px) { .hv-media { object-fit: contain; } }

  .hv-scrim {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: linear-gradient(180deg, rgba(8,13,26,0.3) 0%, transparent 22%, transparent 50%, rgba(8,13,26,0.85) 100%);
  }

  .hv-overlay {
    position: absolute; left: 0; right: 0; bottom: 5rem; z-index: 2; text-align: center;
    padding: 0 1.5rem;
    display: flex; flex-direction: column; align-items: center; gap: 1.3rem;
  }
  @media (max-width: 600px) { .hv-overlay { bottom: 3.5rem; } }
  .hv-avail {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.42rem 0.95rem; border-radius: 999px;
    background: rgba(8,13,26,0.62); backdrop-filter: blur(8px);
    border: 1px solid var(--line-strong); font-size: 0.8rem; font-weight: 600; color: var(--ink);
  }
  .hv-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 0 0 rgba(95,185,138,0.6); animation: pulse-dot 2s ease-out infinite; }
  .hv-btns { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  .hv-cue { position: absolute; bottom: 1.3rem; left: 50%; transform: translateX(-50%); z-index: 3; width: 22px; height: 36px; border: 1px solid var(--line-strong); border-radius: 999px; }
  .hv-cue span { position: absolute; top: 6px; left: 50%; width: 3px; height: 7px; margin-left: -1.5px; background: var(--gold); border-radius: 2px; animation: hv-scroll 1.8s ease-in-out infinite; }
  @keyframes hv-scroll { 0% { opacity: 0; transform: translateY(0); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(12px); } }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
</style>
