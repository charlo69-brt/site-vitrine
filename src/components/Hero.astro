---
import { Image } from "astro:assets";
import character from "../assets/character.png";
import chatBubbleIcon from "../assets/icons/chat-bubble.png";
import euroIcon from "../assets/icons/euro.png";
import chartIcon from "../assets/icons/chart.png";
import keyIcon from "../assets/icons/key.png";
import umbrellaIcon from "../assets/icons/umbrella.png";
import walletIcon from "../assets/icons/wallet.png";
import { profile, timeline } from "../data/profile";

// 3D icons from 3dicons.co (CC0 — free, no attribution required).
// Each appears staggered, as if surfacing one by one during a conversation,
// hugging the edges of the character's dark stage card.
const sceneIcons = [
  { src: chatBubbleIcon, alt: "Conseil", top: "9%", left: "16%", size: 78, delay: 0, floatDelay: 0 },
  { src: euroIcon, alt: "Budget", top: "9%", left: "82%", size: 72, delay: 220, floatDelay: 300 },
  { src: chartIcon, alt: "Croissance du patrimoine", top: "32%", left: "85%", size: 94, delay: 420, floatDelay: 900 },
  { src: keyIcon, alt: "Immobilier", top: "52%", left: "12%", size: 78, delay: 600, floatDelay: 1500 },
  { src: umbrellaIcon, alt: "Protection", top: "88%", left: "84%", size: 84, delay: 780, floatDelay: 600 },
  { src: walletIcon, alt: "Épargne", top: "90%", left: "20%", size: 76, delay: 950, floatDelay: 1100 },
];

const birth = new Date(profile.birthDate);
const ageMs = Date.now() - birth.getTime();
const age = Math.floor(ageMs / (1000 * 60 * 60 * 24 * 365.25));

const facts = [profile.location, profile.drivingLicense];

const experienceEntries = timeline.filter((entry) => entry.kind === "experience");
const educationEntries = timeline.filter((entry) => entry.kind === "education");
const firstExperience = new Date(`${experienceEntries[0].date}-01`);
const experienceYears = Math.floor(
  (Date.now() - firstExperience.getTime()) / (1000 * 60 * 60 * 24 * 365.25),
);

const stats = [
  { value: age, suffix: "", label: "Ans" },
  { value: experienceYears, suffix: "+", label: "Ans de terrain" },
  { value: educationEntries.length, suffix: "", label: "Étapes de formation" },
];
---

<section class="hero" id="accueil">
  <div class="hero-bg bg-grid-soft" aria-hidden="true">
    <svg viewBox="0 0 600 200" preserveAspectRatio="none" class="hero-line">
      <defs>
        <linearGradient id="heroLineGradient" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#2f6fed" />
          <stop offset="100%" stop-color="#1fae6e" />
        </linearGradient>
      </defs>
      <path
        d="M0,170 C90,150 130,110 200,120 C280,132 320,70 400,55 C470,42 520,55 600,10"
        pathLength="100"
      />
    </svg>
  </div>

  <div class="container hero-inner">
    <div class="hero-text">
      <p class="section-label">{profile.role}</p>
      <h1>{profile.name}</h1>
      <p class="tagline">{profile.tagline}</p>

      <ul class="facts">
        {facts.map((fact) => <li>{fact}</li>)}
      </ul>

      <ul class="stats" data-reveal>
        {stats.map((stat) => (
          <li>
            <span class="stat-value" data-animate-count={stat.value} data-count-suffix={stat.suffix}>
              {stat.value}{stat.suffix}
            </span>
            <span class="stat-label">{stat.label}</span>
          </li>
        ))}
      </ul>

      <div class="actions">
        <a href="#contact" class="btn btn-primary">Me contacter</a>
        <a href="#parcours" class="btn btn-secondary">Voir mon parcours</a>
      </div>
    </div>

    <div class="hero-scene" data-reveal>
      <div class="hero-stage bg-grid">
        <Image src={character} alt={profile.name} width={438} height={660} class="stage-photo" />
      </div>
      {sceneIcons.map((icon) => (
        <div
          class="scene-icon"
          style={`top:${icon.top}; left:${icon.left}; width:${icon.size}px; transition-delay:${icon.delay}ms`}
        >
          <div class="scene-icon-float" style={`animation-delay:-${icon.floatDelay}ms`}>
            <Image src={icon.src} alt={icon.alt} width={200} height={200} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, #eef1f6 0%, var(--color-bg) 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-line {
    position: absolute;
    right: -4%;
    bottom: 0;
    width: 65%;
    height: 55%;
    opacity: 0.25;
  }

  .hero-line path {
    fill: none;
    stroke: url(#heroLineGradient);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: draw-hero-line 2.4s ease 0.3s forwards;
  }

  @keyframes draw-hero-line {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-text h1 {
    font-size: 3rem;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .tagline {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin-bottom: 2rem;
  }

  .facts li {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .stats {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin-bottom: 2rem;
  }

  .stat-value {
    display: block;
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-scene {
    position: relative;
    justify-self: center;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1 / 1.2;
  }

  .hero-stage {
    position: absolute;
    inset: 7% 14%;
    border-radius: 28px;
    overflow: hidden;
    background: linear-gradient(160deg, var(--color-navy-deep), var(--color-navy));
    box-shadow: 0 24px 48px rgba(10, 18, 36, 0.25);
  }

  .stage-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .scene-icon {
    position: absolute;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .hero-scene.is-visible .scene-icon {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .scene-icon-float {
    animation: icon-float 4.5s ease-in-out infinite;
  }

  .scene-icon img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 14px 18px rgba(18, 32, 57, 0.18));
  }

  @keyframes icon-float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text h1 {
      font-size: 2.2rem;
    }

    .tagline {
      margin-left: auto;
      margin-right: auto;
    }

    .facts,
    .actions,
    .stats {
      justify-content: center;
    }

    .hero-scene {
      order: -1;
      max-width: 280px;
    }

    .hero-line {
      width: 90%;
      opacity: 0.16;
    }
  }
</style>
