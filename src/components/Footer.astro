---
import { profile } from "../data/profile";
const year = new Date().getFullYear();
---

<footer class="footer">
  <hr class="rule" />
  <div class="container footer-inner" data-reveal>
    <span class="footer-logo">{profile.name}</span>
    <p class="footer-role">{profile.role}</p>
    <p class="footer-copy">© {year} — Tous droits réservés</p>
  </div>
</footer>

<style>
  .footer { padding: 2.5rem 0 3rem; }
  .footer-inner { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; padding-top: 2.5rem; text-align: center; }
  .footer-logo { font-family: var(--font-display); font-size: 1.4rem; color: var(--ink); }
  .footer-role { font-style: italic; color: var(--gold); font-family: var(--font-display); font-size: 1.05rem; }
  .footer-copy { color: var(--muted-2); font-size: 0.82rem; margin-top: 0.4rem; }
</style>
