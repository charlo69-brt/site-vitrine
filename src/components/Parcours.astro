---
import { experiences, education, interests } from "../data/profile";
---

<section class="section" id="parcours">
  <div class="container">
    <p class="section-label">Mon parcours</p>
    <h2 class="section-title">Expériences &amp; formation</h2>

    <div class="grid">
      <div>
        <h3 class="block-title">Expériences professionnelles</h3>
        <ol class="timeline">
          {experiences.map((exp) => (
            <li class="timeline-item">
              <div class="timeline-head">
                <h4>{exp.role}</h4>
                <span class="period">
                  {exp.period}
                  {exp.current && <span class="badge">En cours</span>}
                </span>
              </div>
              <p class="company">{exp.company} · {exp.contract}</p>
              <ul class="tasks">
                {exp.tasks.map((task) => <li>{task}</li>)}
              </ul>
            </li>
          ))}
        </ol>
      </div>

      <div class="side">
        <div>
          <h3 class="block-title">Formation</h3>
          <ul class="education">
            {education.map((item) => (
              <li>
                <span class="year">{item.year}</span>
                <span class="edu-title">{item.title}</span>
                {item.school && <span class="school">{item.school}</span>}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="block-title">Centres d'intérêt</h3>
          <ul class="interests">
            {interests.map((interest) => <li>{interest}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
  }

  .block-title {
    font-size: 1.1rem;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }

  .timeline {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-item::before {
    content: "";
    position: absolute;
    left: -1.62rem;
    top: 0.3rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .timeline-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .timeline-head h4 {
    font-size: 1.05rem;
    color: var(--color-navy);
  }

  .period {
    font-size: 0.85rem;
    color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge {
    background: var(--color-accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .company {
    color: var(--color-muted);
    font-size: 0.92rem;
    margin: 0.25rem 0 0.6rem;
  }

  .tasks {
    list-style: disc;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: var(--color-text);
    font-size: 0.92rem;
  }

  .side {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .education {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .education li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .year {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .edu-title {
    font-size: 0.95rem;
    color: var(--color-navy);
  }

  .school {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .interests {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .interests li {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  @media (max-width: 800px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
