---
import { timeline, interests } from "../data/profile";

// Icônes (Lucide) par centre d'intérêt — fallback losange si inconnu
const interestIcons: Record<string, string> = {
  Sport: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  Informatique: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  Finance: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  Musique: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
};
const fallbackIcon = '<path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/>';

// Ce que chaque centre d'intérêt apporte (lien avec la posture pro)
const interestMeta: Record<string, string> = {
  Sport: "Rigueur, endurance et goût du dépassement.",
  Informatique: "Veille tech et maîtrise des outils du métier.",
  Finance: "Passion des marchés, de l'économie et du patrimoine.",
  Musique: "Sens du rythme, créativité et discipline.",
};
const interestData = interests.map((name) => ({
  name,
  key: name.toLowerCase(),
  icon: interestIcons[name] ?? fallbackIcon,
  desc: interestMeta[name] ?? "",
}));

// Tracé « pouls/cardio » de la carte Sport — un battement répété tous les 50px
// (motif identique → translation de 50px en boucle = défilement sans couture)
const beat = (o: number) => `L${o + 15} 20 L${o + 20} 20 L${o + 24} 7 L${o + 29} 33 L${o + 33} 20 L${o + 50} 20`;
const pulsePath = "M0 20 " + [0, 50, 100, 150, 200, 250].map(beat).join(" ");

const WIDTH = 1000;
const HEIGHT = 380;
const PAD_X = 36;
const PAD_TOP = 64;
const PAD_BOTTOM = 56;

function monthIndex(date: string) {
  const [year, month] = date.split("-").map(Number);
  return year * 12 + (month - 1);
}

const months = timeline.map((entry) => monthIndex(entry.date));
const minMonth = months[0];
const maxMonth = months[months.length - 1];
const span = maxMonth - minMonth || 1;
const count = timeline.length;

// Blend real chronological spacing with even spacing so close milestones
// (e.g. two diplomas a month apart) don't collapse into each other.
const BLEND = 0.55;
const fractions = months.map((month, i) => {
  const raw = (month - minMonth) / span;
  const even = count > 1 ? i / (count - 1) : 0;
  return raw * (1 - BLEND) + even * BLEND;
});

const scores = timeline.map((entry) => entry.score);
const minScore = Math.min(...scores) - 8;
const maxScore = Math.max(...scores) + 10;
const scoreSpan = maxScore - minScore || 1;

const innerWidth = WIDTH - PAD_X * 2;
const innerHeight = HEIGHT - PAD_TOP - PAD_BOTTOM;

const points = timeline.map((entry, i) => {
  const x = PAD_X + fractions[i] * innerWidth;
  const y = PAD_TOP + (1 - (entry.score - minScore) / scoreSpan) * innerHeight;
  const year = entry.date.slice(0, 4);
  const prevYear = i > 0 ? timeline[i - 1].date.slice(0, 4) : null;

  return {
    ...entry,
    x,
    y,
    xPct: (x / WIDTH) * 100,
    yPct: (y / HEIGHT) * 100,
    yearTick: year !== prevYear ? year : null,
    gain: i > 0 ? entry.score - timeline[i - 1].score : null,
  };
});

function buildSmoothPath(pts: { x: number; y: number }[]) {
  if (pts.length < 2) return "";
  let d = `M ${pts[0].x} ${pts[0].y}`;
  for (let i = 0; i < pts.length - 1; i++) {
    const p0 = pts[i - 1] ?? pts[i];
    const p1 = pts[i];
    const p2 = pts[i + 1];
    const p3 = pts[i + 2] ?? p2;
    const c1x = p1.x + (p2.x - p0.x) / 6;
    const c1y = p1.y + (p2.y - p0.y) / 6;
    const c2x = p2.x - (p3.x - p1.x) / 6;
    const c2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2.x} ${p2.y}`;
  }
  return d;
}

const linePath = buildSmoothPath(points);
const baselineY = HEIGHT - PAD_BOTTOM + 22;
const lastPoint = points[points.length - 1];
const firstPoint = points[0];
const areaPath = `${linePath} L ${lastPoint.x} ${baselineY} L ${firstPoint.x} ${baselineY} Z`;
const gridLines = [0, 1, 2, 3].map((i) => PAD_TOP + (innerHeight / 3) * i);

const current = timeline[timeline.length - 1];
const currentGain = current.score - timeline[timeline.length - 2].score;
---

<section class="section parcours" id="parcours">
  <span class="glow glow-gold p-glow" data-depth="0.12" aria-hidden="true"></span>
  <div class="container" data-scene>
    <p class="kicker">Mon parcours</p>
    <h2 class="section-title">Une trajectoire ascendante vers la <span class="gold-text">gestion de patrimoine</span></h2>

    <div class="chart-card bg-grid" data-reveal>
      <div class="chart-header">
        <div>
          <p class="chart-kicker">Expériences &amp; formation — indice de progression</p>
          <p class="chart-hint">Survolez ou sélectionnez un point pour voir le détail</p>
        </div>
        <div class="chart-readout">
          <span class="readout-value" data-animate-count={current.score}>{current.score}</span>
          <span class="readout-gain">
            <svg class="trend-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
              <polyline points="16 7 22 7 22 13" />
            </svg>+{currentGain}
          </span>
          <span class="readout-label">Position actuelle</span>
        </div>
      </div>

      <div class="chart-wrap">
        <svg viewBox={`0 0 ${WIDTH} ${HEIGHT}`} preserveAspectRatio="none" class="chart-svg" aria-hidden="true">
          <defs>
            <linearGradient id="lineGradient" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#e2c992" />
              <stop offset="60%" stop-color="#c8a96a" />
              <stop offset="100%" stop-color="#5fb98a" />
            </linearGradient>
            <linearGradient id="areaGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#c8a96a" stop-opacity="0.3" />
              <stop offset="100%" stop-color="#c8a96a" stop-opacity="0" />
            </linearGradient>
            <filter id="lineGlow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="4" result="b" />
              <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
            </filter>
          </defs>

          {gridLines.map((gy) => (
            <line x1={PAD_X} y1={gy} x2={WIDTH - PAD_X} y2={gy} class="grid-line" />
          ))}

          <path d={areaPath} class="area-fill" fill="url(#areaGradient)" />
          <path d={linePath} class="chart-line" pathLength="100" fill="none" stroke="url(#lineGradient)" filter="url(#lineGlow)" />
          <circle r="5" class="chart-runner" fill="#fff">
            <animateMotion dur="5s" repeatCount="indefinite" rotate="auto" path={linePath} />
          </circle>
        </svg>

        <div class="overlay">
          <span class="crosshair" id="parcours-crosshair" aria-hidden="true"></span>
          {points.map((p, i) =>
            i > 0 && (
              <span
                class="gain-chip"
                style={`left:${(p.xPct + points[i - 1].xPct) / 2}%; top:${(p.yPct + points[i - 1].yPct) / 2}%; transition-delay:${i * 70}ms`}
              >
                +{p.gain}
              </span>
            )
          )}

          {points.map((p) =>
            p.yearTick && (
              <span class="year-tick" style={`left:${p.xPct}%`}>{p.yearTick}</span>
            )
          )}

          {points.map((p, i) => (
            <button
              type="button"
              class={`marker marker-${p.kind} ${p.current ? "is-current" : ""}`}
              style={`left:${p.xPct}%; top:${p.yPct}%; transition-delay:${i * 70}ms`}
              data-label={p.label}
              data-kind={p.kind}
              data-org={p.org ?? ""}
              data-period={p.period}
              data-current={p.current ? "1" : ""}
              data-details={JSON.stringify(p.details)}
              aria-label={`${p.label}${p.org ? " — " + p.org : ""}, ${p.period}`}
            >
              <span class="marker-dot" aria-hidden="true"></span>
              {p.current && <span class="ath-badge" aria-hidden="true">ATH</span>}
            </button>
          ))}
        </div>

        <div class="point-tooltip" id="parcours-tooltip" role="status"></div>
      </div>

      <div class="legend">
        <span class="legend-item"><span class="legend-dot legend-experience"></span>Expérience</span>
        <span class="legend-item"><span class="legend-dot legend-education"></span>Formation</span>
      </div>

      <div class="detail-panel" id="parcours-detail" aria-live="polite">
        <div class="detail-top">
          <span class={`detail-kind detail-kind--${current.kind}`}>{current.kind === "education" ? "Formation" : "Expérience"}</span>
          <span class="detail-period">
            {current.period}
            {current.current && <em class="badge-live">En cours</em>}
          </span>
        </div>
        <h3 class="detail-title">{current.label}</h3>
        {current.org && <p class="detail-org">{current.org}</p>}
        <ul class="detail-list">
          {current.details.map((line) => <li>{line}</li>)}
        </ul>
      </div>
    </div>

    <div class="interests-block" data-reveal>
      <p class="interests-eyebrow">Au-delà du métier</p>
      <h3 class="interests-title">Centres d'<span class="gold-text">intérêt</span></h3>
      <div class="interest-grid">
        {interestData.map((it, i) => (
          <article
            class={`interest-card${it.key === "finance" ? " interest-card--finance" : ""}`}
            style={`--i:${i}`}
            data-interest={it.key}
            data-spotlight
            data-tilt="6"
            {...(it.key === "finance" ? { "data-fin-open": "", role: "button", tabindex: "0", "aria-label": "Ouvrir le graphique du marché" } : {})}
          >
            <span class="interest-ico-wrap">
              <svg class="interest-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.icon} />
            </span>
            <h4 class="ic-name">{it.name}</h4>
            {it.key === "finance" ? (
              <div class="fin-live">
                <div class="fin-top"><span class="fin-sym">BTC / EUR</span><span class="fin-chg" id="fin-chg">···</span></div>
                <div class="fin-price" id="fin-price">···</div>
                <svg class="fin-spark" viewBox="0 0 200 40" preserveAspectRatio="none" aria-hidden="true">
                  <path class="fin-area" id="fin-area" />
                  <path class="fin-line" id="fin-line" />
                </svg>
                <span class="fin-cta">Voir le graphique →</span>
              </div>
            ) : it.key === "sport" ? (
              <>
                <p class="ic-desc">{it.desc}</p>
                <div class="sport-pulse" aria-hidden="true">
                  <svg viewBox="0 0 200 40" preserveAspectRatio="none">
                    <g class="pulse-scroll"><path class="pulse-line" d={pulsePath} /></g>
                  </svg>
                </div>
              </>
            ) : (
              <p class="ic-desc">{it.desc}</p>
            )}
          </article>
        ))}
      </div>

    </div>
  </div>

  <!-- Modale : hors du conteneur transformé [data-scene] pour un position:fixed correct -->
  <div class="fin-modal" id="fin-modal" hidden>
    <div class="fin-backdrop" data-fin-close aria-hidden="true"></div>
    <div class="fin-dialog glass" role="dialog" aria-modal="true" aria-label="Graphique du marché Bitcoin">
      <button type="button" class="fin-close" data-fin-close aria-label="Fermer">✕</button>
      <div class="fin-dialog-head">
        <div>
          <span class="fin-eyebrow">Marché · 30 jours</span>
          <h3>Bitcoin · <span class="gold-text">BTC / EUR</span></h3>
        </div>
        <div class="fin-dialog-stats"><b id="fin-big">···</b><span class="fin-chg" id="fin-chg2">···</span></div>
      </div>
      <svg class="fin-big-chart" viewBox="0 0 600 240" preserveAspectRatio="none" aria-hidden="true">
        <path class="fin-area" id="fin-barea" />
        <path class="fin-line" id="fin-bline" />
      </svg>
      <p class="fin-note">Cours en direct via Coinbase · illustratif, ne constitue pas un conseil en investissement.</p>
    </div>
  </div>

</section>

<script>
  function setupParcoursChart() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".marker");
    const panel = document.getElementById("parcours-detail");
    const tooltip = document.getElementById("parcours-tooltip");
    if (!panel || buttons.length === 0) return;

    const crosshair = document.getElementById("parcours-crosshair");

    function showTooltip(button: HTMLButtonElement) {
      if (crosshair) {
        crosshair.style.left = button.style.left;
        crosshair.classList.add("is-visible");
      }
      if (!tooltip) return;
      const { label, period } = button.dataset;
      tooltip.replaceChildren();

      const titleEl = document.createElement("strong");
      titleEl.textContent = label ?? "";
      const periodEl = document.createElement("span");
      periodEl.textContent = period ?? "";

      tooltip.append(titleEl, periodEl);
      tooltip.style.left = button.style.left;
      tooltip.style.top = button.style.top;
      tooltip.classList.add("is-visible");
    }

    function hideTooltip() {
      tooltip?.classList.remove("is-visible");
      crosshair?.classList.remove("is-visible");
    }

    function render(button: HTMLButtonElement) {
      const { label, org, period, current, details, kind } = button.dataset;
      const items: string[] = JSON.parse(details || "[]");

      panel!.replaceChildren();

      const top = document.createElement("div");
      top.className = "detail-top";

      const kindEl = document.createElement("span");
      kindEl.className = "detail-kind detail-kind--" + (kind || "experience");
      kindEl.textContent = kind === "education" ? "Formation" : "Expérience";

      const periodEl = document.createElement("span");
      periodEl.className = "detail-period";
      periodEl.append(period ?? "");
      if (current) {
        const badge = document.createElement("em");
        badge.className = "badge-live";
        badge.textContent = "En cours";
        periodEl.append(" ", badge);
      }
      top.append(kindEl, periodEl);

      const title = document.createElement("h3");
      title.className = "detail-title";
      title.textContent = label ?? "";

      panel!.append(top, title);

      if (org) {
        const orgEl = document.createElement("p");
        orgEl.className = "detail-org";
        orgEl.textContent = org;
        panel!.append(orgEl);
      }

      const list = document.createElement("ul");
      list.className = "detail-list";
      for (const item of items) {
        const li = document.createElement("li");
        li.textContent = item;
        list.append(li);
      }
      panel!.append(list);

      for (const b of buttons) {
        b.classList.toggle("is-active", b === button);
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("mouseenter", () => {
        render(button);
        showTooltip(button);
      });
      button.addEventListener("focus", () => {
        render(button);
        showTooltip(button);
      });
      button.addEventListener("click", () => render(button));
      button.addEventListener("mouseleave", hideTooltip);
      button.addEventListener("blur", hideTooltip);
    });
  }

  setupParcoursChart();

  // Carte Finance : mini-graphique BTC/EUR live (Coinbase Exchange) + modale 30 jours
  async function setupFinance() {
    const card = document.querySelector<HTMLElement>("[data-fin-open]");
    if (!card) return;

    const eur = (n: number) => Math.round(n).toLocaleString("fr-FR") + " €";
    const setText = (id: string, t: string) => { const el = document.getElementById(id); if (el) el.textContent = t; };
    const setPath = (id: string, d: string) => { const el = document.getElementById(id); if (el) el.setAttribute("d", d); };

    let closes: number[] = [];
    try {
      const r = await fetch("https://api.exchange.coinbase.com/products/BTC-EUR/candles?granularity=86400", { cache: "no-store" });
      if (r.ok) {
        const data = (await r.json()) as number[][]; // [time, low, high, open, close, vol], plus récent d'abord
        closes = data.slice(0, 30).map((c) => c[4]).reverse();
      }
    } catch {}

    if (closes.length >= 2) {
      const last = closes[closes.length - 1];
      const prev = closes[closes.length - 2];
      const chg = ((last - prev) / prev) * 100;
      const chgTxt = `${chg >= 0 ? "▲ +" : "▼ "}${chg.toFixed(2)} %`;
      setText("fin-price", eur(last));
      setText("fin-big", eur(last));
      for (const id of ["fin-chg", "fin-chg2"]) { const el = document.getElementById(id); if (el) { el.textContent = chgTxt; el.classList.add(chg >= 0 ? "up" : "down"); } }

      const build = (vals: number[], w: number, h: number, pad: number) => {
        const min = Math.min(...vals), max = Math.max(...vals), span = (max - min) || 1;
        const pts = vals.map((v, i) => ({ x: (i / (vals.length - 1)) * w, y: pad + (1 - (v - min) / span) * (h - 2 * pad) }));
        const line = pts.map((p, i) => `${i ? "L" : "M"}${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(" ");
        return { line, area: `${line} L ${w} ${h} L 0 ${h} Z` };
      };
      const mini = build(closes, 200, 40, 3);
      setPath("fin-line", mini.line); setPath("fin-area", mini.area);
      const big = build(closes, 600, 240, 10);
      setPath("fin-bline", big.line); setPath("fin-barea", big.area);
    } else {
      setText("fin-price", "Indisponible"); setText("fin-chg", "");
    }

    const modal = document.getElementById("fin-modal");
    const open = () => { modal?.removeAttribute("hidden"); document.body.style.overflow = "hidden"; };
    const close = () => { modal?.setAttribute("hidden", ""); document.body.style.overflow = ""; };
    card.addEventListener("click", open);
    card.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(); } });
    document.querySelectorAll("[data-fin-close]").forEach((el) => el.addEventListener("click", close));
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal && !modal.hasAttribute("hidden")) close(); });
  }
  setupFinance();
</script>

<style>
  .chart-card {
    position: relative;
    background: linear-gradient(160deg, #0c1428, #070b16);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 2.25rem;
    color: var(--ink);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .parcours { overflow: hidden; }
  .p-glow { width: 30rem; height: 30rem; top: 10%; right: -12rem; opacity: 0.25; }
  .block-title { color: var(--ink); }

  .chart-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .chart-kicker {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #9db3dd;
    margin-bottom: 0.35rem;
  }

  .chart-hint {
    font-size: 0.85rem;
    color: #c7d0e6;
  }

  .chart-readout {
    text-align: right;
  }

  .readout-value {
    display: block;
    font-size: 2.1rem;
    font-weight: 700;
    line-height: 1;
  }

  .readout-gain {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: var(--green);
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.2rem;
  }

  .trend-ico {
    width: 0.95em;
    height: 0.95em;
    flex-shrink: 0;
  }

  .readout-label {
    display: block;
    font-size: 0.72rem;
    color: #9db3dd;
    margin-top: 0.15rem;
  }

  .chart-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1000 / 380;
  }

  .chart-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .grid-line {
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 1;
  }

  .area-fill {
    opacity: 0;
    transition: opacity 1s ease 0.4s;
  }

  .chart-line {
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 1.6s ease;
  }

  .chart-card.is-visible .area-fill {
    opacity: 1;
  }

  .chart-card.is-visible .chart-line {
    stroke-dashoffset: 0;
  }

  .chart-runner {
    filter: drop-shadow(0 0 6px rgba(126, 240, 189, 0.9));
    opacity: 0;
  }

  .chart-card.is-visible .chart-runner {
    opacity: 1;
    transition: opacity 0.6s ease 1.6s;
  }

  .overlay {
    position: absolute;
    inset: 0;
  }

  .crosshair {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.5), transparent);
    opacity: 0;
    transition: opacity 0.2s ease, left 0.15s ease;
    pointer-events: none;
  }

  .crosshair.is-visible {
    opacity: 1;
  }

  .year-tick {
    position: absolute;
    bottom: -1.6rem;
    transform: translateX(-50%);
    font-size: 0.8rem;
    font-weight: 600;
    color: #93a4c9;
  }

  .gain-chip {
    position: absolute;
    transform: translate(-50%, -180%);
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--green);
    background: rgba(95,185,138, 0.12);
    border: 1px solid rgba(95,185,138, 0.35);
    border-radius: 999px;
    padding: 0.05rem 0.4rem;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .chart-card.is-visible .gain-chip {
    opacity: 1;
  }

  .marker {
    position: absolute;
    width: 44px;
    height: 44px;
    transform: translate(-50%, -50%) scale(0.4);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chart-card.is-visible .marker {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .marker:hover,
  .marker:focus-visible,
  .marker.is-active {
    transform: translate(-50%, -50%) scale(1.35);
  }

  .marker-dot {
    width: 14px;
    height: 14px;
    background: var(--gold);
    border: 2px solid #0a1224;
