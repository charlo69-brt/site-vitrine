---
import { Image } from "astro:assets";
import photo from "../assets/photo.png";
import { about, profile } from "../data/profile";
---

<section class="section" id="a-propos">
  <div class="container about-grid">
    <div class="about-inner">
      <p class="section-label" data-reveal>Qui suis-je</p>
      <h2 class="section-title" data-reveal style="transition-delay: 60ms">À propos</h2>
      <p class="about-text" data-reveal style="transition-delay: 120ms">{about}</p>
    </div>

    <div class="photo-bubble" data-reveal style="transition-delay: 180ms">
      <Image src={photo} alt={profile.name} width={280} height={280} />
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 0.5fr;
    align-items: center;
    gap: 3rem;
  }

  .about-inner {
    position: relative;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-accent);
  }

  .about-text {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .photo-bubble {
    justify-self: center;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--color-surface);
    box-shadow: 0 18px 36px rgba(18, 32, 57, 0.16);
    background: var(--color-navy);
  }

  .photo-bubble img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 700px) {
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-inner {
      padding-left: 0;
      border-left: none;
    }

    .photo-bubble {
      order: -1;
    }
  }
</style>
