---
import { projects, achievement, skills, languages } from "../data/profile";
---

<section class="section" id="projets">
  <div class="container">
    <p class="section-label">Réalisations</p>
    <h2 class="section-title">Projets &amp; compétences</h2>

    <div class="top-grid">
      {projects.map((project, i) => (
        <article class="card project-card" data-reveal style={`transition-delay:${i * 90}ms`}>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {project.linkLabel}
          </a>
        </article>
      ))}

      <article class="card achievement-card" data-reveal style={`transition-delay:${projects.length * 90}ms`}>
        <h3>{achievement.title}</h3>
        <p>{achievement.description}</p>
      </article>
    </div>

    <div class="bottom-grid">
      <div class="card" data-reveal>
        <h3 class="block-title">Compétences techniques</h3>
        <ul class="skills">
          {skills.map((skill) => (
            <li>
              <div class="skill-head">
                <span>{skill.name}</span>
                <span>{skill.level}%</span>
              </div>
              <div class="bar">
                <div class="bar-fill" data-animate-bar={skill.level}></div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="card" data-reveal style="transition-delay: 90ms">
        <h3 class="block-title">Langues</h3>
        <ul class="languages">
          {languages.map((lang) => (
            <li>
              <span>{lang.name}</span>
              <span class="level">{lang.level}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .top-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .project-card h3 {
    color: var(--color-navy);
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
  }

  .project-card p {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .achievement-card {
    background: var(--color-navy);
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .achievement-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .achievement-card p {
    color: #c7d0e6;
    font-size: 0.95rem;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1.5rem;
  }

  .block-title {
    font-size: 1.05rem;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }

  .skills {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-head {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .bar {
    height: 8px;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--color-accent), var(--color-gain));
    border-radius: 999px;
    transition: width 1.1s ease;
  }

  .languages {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .languages li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .level {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  @media (max-width: 800px) {
    .top-grid {
      grid-template-columns: 1fr;
    }

    .bottom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
