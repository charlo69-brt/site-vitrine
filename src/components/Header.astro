---
import { profile } from "../data/profile";

const links = [
  { href: "#accueil", label: "Accueil" },
  { href: "#approche", label: "Approche" },
  { href: "#simulateur", label: "Simulateur" },
  { href: "#parcours", label: "Parcours" },
  { href: "#projets", label: "Projets" },
  { href: "#contact", label: "Contact" },
];
---

<header class="header" id="site-header">
  <div class="container header-inner">
    <a href="#accueil" class="logo">{profile.name}</a>

    <nav class="nav" id="nav">
      <ul>
        {links.map((link) => (
          <li><a href={link.href} data-nav-link={link.href.slice(1)}>{link.label}</a></li>
        ))}
        <li class="nav-cta"><a href="#contact" class="btn btn-gold" data-magnetic><span class="d"></span>Disponible</a></li>
      </ul>
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("nav");
  const header = document.getElementById("site-header");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });
  nav?.querySelectorAll("a").forEach((link) =>
    link.addEventListener("click", () => {
      nav.classList.remove("open");
      toggle?.setAttribute("aria-expanded", "false");
    }),
  );
  window.addEventListener("scroll", () => header?.classList.toggle("scrolled", window.scrollY > 40), { passive: true });

  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const sections = document.querySelectorAll<HTMLElement>("section[id]");
  if (sections.length > 0) {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) navLinks.forEach((l) => l.classList.toggle("active", l.dataset.navLink === e.target.id));
      }),
      { rootMargin: "-45% 0px -45% 0px" },
    );
    sections.forEach((s) => obs.observe(s));
  }
</script>

<style>
  .header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(10, 15, 31, 0.55);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .header.scrolled { background: rgba(10, 15, 31, 0.85); border-bottom-color: var(--line); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 4.75rem; }

  .logo { font-family: var(--font-display); font-weight: 600; font-size: 1.35rem; letter-spacing: 0.01em; color: var(--ink); }

  .nav ul { display: flex; align-items: center; gap: 1.9rem; list-style: none; }
  .nav a { position: relative; font-size: 0.9rem; font-weight: 500; color: var(--muted); transition: color 0.2s ease; }
  .nav a::after { content: ""; position: absolute; left: 0; bottom: -0.45rem; width: 100%; height: 1px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.25s ease; }
  .nav a:hover, .nav a.active { color: var(--ink); }
  .nav a.active::after { transform: scaleX(1); }

  .nav-cta .btn { padding: 0.45rem 1.1rem; font-size: 0.82rem; }
  .nav-cta .btn::after { display: none; }
  .nav-cta .d { width: 7px; height: 7px; border-radius: 50%; background: #1a3a28; box-shadow: 0 0 0 0 rgba(26, 58, 40, 0.6); animation: pulse-dot 2s ease-out infinite; }

  .nav-toggle { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 2rem; height: 2rem; background: none; border: none; cursor: pointer; padding: 0; }
  .nav-toggle span { display: block; height: 2px; background: var(--ink); border-radius: 2px; }

  @media (max-width: 820px) {
    .nav-toggle { display: flex; }
    .nav { position: absolute; top: 4.75rem; left: 0; right: 0; background: rgba(10, 15, 31, 0.96); border-bottom: 1px solid var(--line); max-height: 0; overflow: hidden; transition: max-height 0.25s ease; }
    .nav.open { max-height: 26rem; }
    .nav ul { flex-direction: column; gap: 0; align-items: stretch; padding: 0.5rem 1.75rem 1.5rem; }
    .nav li { padding: 0.7rem 0; border-bottom: 1px solid var(--line); }
    .nav-cta { padding-top: 1rem; border-bottom: none; }
    .nav-cta .btn { justify-content: center; }
  }
</style>
