---
import { profile } from "../data/profile";
---

<section class="section contact" id="contact">
  <div class="container contact-layout">
    <div class="contact-intro">
      <p class="section-label" data-reveal>Contact</p>
      <h2 class="section-title" data-reveal style="transition-delay: 60ms">Travaillons ensemble</h2>
      <p class="contact-text" data-reveal style="transition-delay: 120ms">
        Disponible pour échanger sur une opportunité en conseil en gestion de patrimoine. N'hésitez pas à me contacter.
      </p>

      <ul class="contact-quick" data-reveal style="transition-delay: 180ms">
        <li>
          <span class="label">Email</span>
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
        </li>
        <li>
          <span class="label">Téléphone</span>
          <a href={`tel:${profile.phone.replace(/\s/g, "")}`}>{profile.phone}</a>
        </li>
        <li>
          <span class="label">Localisation</span>
          <span>{profile.location}</span>
        </li>
      </ul>
    </div>

    <form class="contact-form card" data-reveal style="transition-delay: 90ms" id="contact-form" data-to={profile.email}>
      <div class="form-row">
        <label>
          Nom
          <input type="text" name="name" placeholder="Votre nom" required />
        </label>
        <label>
          Email
          <input type="email" name="email" placeholder="vous@exemple.com" required />
        </label>
      </div>

      <label>
        Sujet
        <input type="text" name="subject" placeholder="Opportunité, question..." />
      </label>

      <label>
        Message
        <textarea name="message" rows="5" placeholder="Votre message" required></textarea>
      </label>

      <button type="submit" class="btn btn-primary">Envoyer le message</button>
      <p class="form-hint">Ouvre votre messagerie avec le message déjà rempli, à destination de {profile.email}.</p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const name = String(data.get("name") ?? "");
    const email = String(data.get("email") ?? "");
    const subject = String(data.get("subject") ?? "") || `Contact via le site — ${name}`;
    const message = String(data.get("message") ?? "");

    const body = `${message}\n\n— ${name} (${email})`;
    const mailto = `mailto:${form.dataset.to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
  });
</script>

<style>
  .contact {
    background: var(--color-navy);
    color: #fff;
  }

  .contact .section-label {
    color: #8fb3ff;
  }

  .contact .section-title {
    color: #fff;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-text {
    color: #c7d0e6;
    max-width: 36rem;
    margin-bottom: 2rem;
  }

  .contact-quick {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .contact-quick li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-quick .label {
    font-size: 0.75rem;
    color: #8fa0c7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-quick a,
  .contact-quick span:not(.label) {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .contact-quick a {
    transition: color 0.15s ease;
  }

  .contact-quick a:hover {
    color: var(--color-accent);
  }

  .contact-form {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 0.85rem;
    color: #c7d0e6;
  }

  .contact-form input,
  .contact-form textarea {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    padding: 0.7rem 0.9rem;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    resize: vertical;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #6b7aa0;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.12);
  }

  .contact-form button {
    align-self: flex-start;
  }

  .form-hint {
    font-size: 0.8rem;
    color: #7e8fb8;
    margin-top: -0.5rem;
  }

  @media (max-width: 800px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-intro {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
