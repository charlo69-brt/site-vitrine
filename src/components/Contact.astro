---
import { profile } from "../data/profile";
---

<section class="section contact" id="contact">
  <div class="container contact-inner">
    <p class="section-label" data-reveal>Contact</p>
    <h2 class="section-title" data-reveal style="transition-delay: 60ms">Travaillons ensemble</h2>
    <p class="contact-text" data-reveal style="transition-delay: 120ms">
      Disponible pour échanger sur une opportunité en conseil en gestion de patrimoine. N'hésitez pas à me contacter.
    </p>

    <div class="contact-grid">
      <a href={`mailto:${profile.email}`} class="card contact-item" data-reveal>
        <span class="label">Email</span>
        <span class="value">{profile.email}</span>
      </a>
      <a href={`tel:${profile.phone.replace(/\s/g, "")}`} class="card contact-item" data-reveal style="transition-delay: 90ms">
        <span class="label">Téléphone</span>
        <span class="value">{profile.phone}</span>
      </a>
      <div class="card contact-item" data-reveal style="transition-delay: 180ms">
        <span class="label">Localisation</span>
        <span class="value">{profile.location}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-navy);
    color: #fff;
  }

  .contact .section-label {
    color: #8fb3ff;
  }

  .contact .section-title {
    color: #fff;
  }

  .contact-text {
    color: #c7d0e6;
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .contact-item {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: background 0.15s ease;
  }

  .contact-item:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .label {
    font-size: 0.8rem;
    color: #8fa0c7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .value {
    font-size: 1rem;
    font-weight: 600;
    word-break: break-word;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
