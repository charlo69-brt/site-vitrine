---
import { profile } from "../data/profile";
---

<section class="section contact" id="contact">
  <span class="glow glow-gold c-glow" data-depth="0.12" aria-hidden="true"></span>

  <div class="container contact-layout" data-scene>
    <div class="contact-intro">
      <p class="kicker" data-reveal>Contact</p>
      <h2 class="section-title" data-reveal style="transition-delay: 60ms">Travaillons <span class="gold-text">ensemble</span></h2>
      <p class="contact-text" data-reveal style="transition-delay: 120ms">
        Disponible pour échanger sur une opportunité en conseil en gestion de patrimoine. N'hésitez pas à me contacter.
      </p>

      <ul class="contact-quick" data-reveal style="transition-delay: 180ms">
        <li><span class="label">Email</span><a href={`mailto:${profile.email}`}>{profile.email}</a></li>
        <li><span class="label">Téléphone</span><a href={`tel:${profile.phone.replace(/\s/g, "")}`}>{profile.phone}</a></li>
        <li><span class="label">Localisation</span><span>{profile.location}</span></li>
      </ul>
    </div>

    <form class="contact-form glass" data-reveal style="transition-delay: 90ms" id="contact-form" data-to={profile.email}>
      <div class="form-row">
        <label>Nom<input type="text" name="name" placeholder="Votre nom" required /></label>
        <label>Email<input type="email" name="email" placeholder="vous@exemple.com" required /></label>
      </div>
      <label>Sujet<input type="text" name="subject" placeholder="Opportunité, question..." /></label>
      <label>Message<textarea name="message" rows="5" placeholder="Votre message" required></textarea></label>
      <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp-field" aria-hidden="true" />
      <button type="submit" class="btn btn-gold" data-magnetic>Envoyer le message</button>
      <p class="form-hint">Ouvre votre messagerie avec le message déjà rempli, à destination de {profile.email}.</p>
    </form>
  </div>

  <div class="cta-band">
    <div class="pulse-center" data-reveal>
      <a href={`mailto:${profile.email}?subject=${encodeURIComponent("Prise de contact via le site")}`} class="btn btn-gold cta-big" data-magnetic>Prendre rendez-vous</a>
      <span class="pulse-sub">Échange sans engagement · réponse sous 24–48 h</span>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(form);
    if (String(data.get("company") ?? "").trim() !== "") return;
    const name = String(data.get("name") ?? "");
    const email = String(data.get("email") ?? "");
    const subject = String(data.get("subject") ?? "") || `Contact via le site — ${name}`;
    const message = String(data.get("message") ?? "");
    const body = `${message}\n\n— ${name} (${email})`;
    window.location.href = `mailto:${form.dataset.to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>

<style>
  .contact { overflow: hidden; }
  .c-glow { width: 30rem; height: 30rem; bottom: -12rem; left: 30%; opacity: 0.3; }

  /* Bloc bouton en bas */
  .cta-band { position: relative; z-index: 1; display: flex; justify-content: center; margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--line); }
  .pulse-center { display: flex; flex-direction: column; align-items: center; gap: 0.9rem; text-align: center; }
  .cta-big { font-size: 1.05rem; padding: 1rem 2.3rem; }
  .pulse-sub { font-size: 0.82rem; color: var(--muted); }
  .contact-layout { position: relative; z-index: 1; display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 3.5rem; align-items: start; }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .contact-text { color: var(--muted); max-width: 36rem; margin-bottom: 2rem; }
  .contact-quick { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .contact-quick li { display: flex; flex-direction: column; gap: 0.15rem; }
  .contact-quick .label { font-size: 0.72rem; color: var(--muted-2); text-transform: uppercase; letter-spacing: 0.12em; }
  .contact-quick a, .contact-quick span:not(.label) { color: var(--ink); font-size: 1rem; font-weight: 600; }
  .contact-quick a { transition: color 0.2s ease; }
  .contact-quick a:hover { color: var(--gold); }

  .contact-form { display: flex; flex-direction: column; gap: 1.15rem; padding: 1.85rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-form label { display: flex; flex-direction: column; gap: 0.45rem; font-size: 0.82rem; color: var(--muted); }
  .contact-form input, .contact-form textarea { background: rgba(255, 255, 255, 0.04); border: 1px solid var(--line); border-radius: 10px; padding: 0.75rem 0.95rem; color: var(--ink); font-family: inherit; font-size: 0.95rem; resize: vertical; transition: border-color 0.2s ease, background 0.2s ease; }
  .contact-form input::placeholder, .contact-form textarea::placeholder { color: var(--muted-2); }
  .contact-form input:focus, .contact-form textarea:focus { border-color: var(--line-strong); background: rgba(255, 255, 255, 0.06); outline: none; }
  .contact-form button { align-self: flex-start; }
  .form-hint { font-size: 0.78rem; color: var(--muted-2); margin-top: -0.4rem; }

  @media (max-width: 820px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-intro { text-align: center; display: flex; flex-direction: column; align-items: center; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
