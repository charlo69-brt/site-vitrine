---
import "../styles/global.css";
import { profile } from "../data/profile";
import MarketTicker from "../components/MarketTicker.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} — ${profile.role}`,
  description = profile.tagline,
} = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a1224" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <a href="#contenu" class="skip-link">Aller au contenu</a>
    <!-- Barre de progression de lecture -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <!-- Halo lumineux qui suit le curseur -->
    <div class="spotlight" id="spotlight" aria-hidden="true"></div>
    <!-- Texture grain subtile -->
    <div class="grain" aria-hidden="true"></div>
    <!-- Curseur personnalisé (desktop) -->
    <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>

    <slot />

    <MarketTicker />

    <script>
      import "../scripts/reveal.ts";
      import "../scripts/interactions.ts";
    </script>
  </body>
</html>
